# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for pgvector memory backend
# OPENAI_API_KEY=sk-...

# LLM Configuration
# HAROLD_LLM_MODEL=anthropic:claude-sonnet-4-20250514
# HAROLD_LLM_TEMPERATURE=0.85

# Memory Backends
# HAROLD_MEMORY_BACKEND=in_memory
# HAROLD_TRAJECTORY_BACKEND=in_memory

# PostgreSQL (required when HAROLD_MEMORY_BACKEND=pgvector)
# HAROLD_PG_DSN=postgresql://postgres:postgres@localhost/harold

# Embeddings (used by pgvector backend)
# HAROLD_EMBEDDING_MODEL=openai:text-embedding-3-small
# HAROLD_EMBEDDING_DIMENSIONS=1536

# Neo4j (required when HAROLD_TRAJECTORY_BACKEND=neo4j)
# HAROLD_NEO4J_URI=neo4j://localhost:7687
# HAROLD_NEO4J_USER=neo4j
# HAROLD_NEO4J_PASSWORD=password

# Observability (Arize Phoenix)
# HAROLD_PHOENIX_ENABLED=false
# HAROLD_PHOENIX_ENDPOINT=http://127.0.0.1:6006/v1/traces
